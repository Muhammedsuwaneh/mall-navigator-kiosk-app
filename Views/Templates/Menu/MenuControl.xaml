<UserControl
    x:Class="MallMapKiosk.Views.Templates.Menu.MenuControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:MallMapKiosk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Menu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="85"
    d:DesignWidth="1030"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:UtilityToBrushConverter x:Key="UtilityToBrushConverter" />
    </UserControl.Resources>

    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.ColumnSpan="9"
                Background="#69DFFA"
                CornerRadius="40"
                Opacity=".5" />

            <Border
                Grid.Column="1"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{Binding MenuUtility, Converter={StaticResource UtilityToBrushConverter}, ConverterParameter=Stores}"
                BorderThickness="0,0,0,3"
                CornerRadius="10"
                Cursor="Hand">
                <StackPanel Orientation="Horizontal">


                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding MenuButtonCommand}" CommandParameter="Stores" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <Image
                        Width="40"
                        Height="40"
                        Margin="7,0"
                        Source="/Assets/Images/Shop.png" />
                    <TextBlock
                        Margin="2,10,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                        FontSize="23"
                        Foreground="#fff"
                        Text="{DynamicResource store_str}" />

                </StackPanel>
            </Border>

            <Rectangle
                Grid.Column="2"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <Border
                Grid.Column="3"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{Binding MenuUtility, Converter={StaticResource UtilityToBrushConverter}, ConverterParameter=DiningRoom}"
                BorderThickness="0,0,0,3"
                CornerRadius="10"
                Cursor="Hand">
                <StackPanel Orientation="Horizontal">


                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding MenuButtonCommand}" CommandParameter="DiningRoom" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <Image
                        Width="40"
                        Height="40"
                        Margin="7,0"
                        Source="/Assets/Images/DiningRoom.png" />
                    <TextBlock
                        Margin="2,10,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                        FontSize="23"
                        Foreground="#fff"
                        Text="{DynamicResource dining_str}" />

                </StackPanel>
            </Border>

            <Rectangle
                Grid.Column="4"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <Border
                Grid.Column="5"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{Binding MenuUtility, Converter={StaticResource UtilityToBrushConverter}, ConverterParameter=RestRoom}"
                BorderThickness="0,0,0,3"
                CornerRadius="10"
                Cursor="Hand">
                <StackPanel Orientation="Horizontal">


                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding MenuButtonCommand}" CommandParameter="RestRoom" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <Image
                        Width="40"
                        Height="40"
                        Margin="7,0"
                        Source="/Assets/Images/Toilet.png" />
                    <TextBlock
                        Margin="2,10,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                        FontSize="23"
                        Foreground="#fff"
                        Text="{DynamicResource restrooms_str}" />

                </StackPanel>
            </Border>

            <Rectangle
                Grid.Column="6"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <Border
                Grid.Column="7"
                Padding="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{Binding MenuUtility, Converter={StaticResource UtilityToBrushConverter}, ConverterParameter=EmergencyExit}"
                BorderThickness="0,0,0,3"
                CornerRadius="10"
                Cursor="Hand">
                <StackPanel Orientation="Horizontal">


                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding MenuButtonCommand}" CommandParameter="EmergencyExit" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <Image
                        Width="40"
                        Height="40"
                        Margin="7,0"
                        Source="/Assets/Images/EmergencyExit.png" />
                    <TextBlock
                        Margin="2,10,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                        FontSize="23"
                        Foreground="#fff"
                        Text="{DynamicResource exit_str}" />

                </StackPanel>
            </Border>


        </Grid>
    </Border>
</UserControl>
