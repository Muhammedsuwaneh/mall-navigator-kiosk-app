<UserControl
    x:Class="MallMapKiosk.Views.Templates.Menu.MenuControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Menu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="80"
    d:DesignWidth="1100"
    mc:Ignorable="d">
    <Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="35" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.ColumnSpan="9"
                Background="#69DFFA"
                CornerRadius="40"
                Opacity=".5" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Cursor="Hand"
                Orientation="Horizontal">
                <Image
                    Width="40"
                    Height="40"
                    Margin="10,0"
                    Source="/Assets/Images/Shop.png" />
                <TextBlock
                    Margin="5,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="23"
                    Foreground="#fff"
                    Text="{DynamicResource store_str}" />

                <!--<i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDown">
                        <i:InvokeCommandAction Command="{Binding MenuButtonCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>-->

            </StackPanel>

            <Rectangle
                Grid.Column="2"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <StackPanel
                Grid.Column="3"
                HorizontalAlignment="Center"
                Cursor="Hand"
                Orientation="Horizontal">
                <Image
                    Width="40"
                    Height="40"
                    Margin="10,0"
                    Source="/Assets/Images/DiningRoom.png" />
                <TextBlock
                    Margin="5,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="23"
                    Foreground="#fff"
                    Text="{DynamicResource dining_str}" />
            </StackPanel>

            <Rectangle
                Grid.Column="4"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <StackPanel
                Grid.Column="5"
                HorizontalAlignment="Center"
                Cursor="Hand"
                Orientation="Horizontal">
                <Image
                    Width="45"
                    Height="50"
                    Margin="5,0"
                    Source="/Assets/Images/Toilet.png" />
                <TextBlock
                    Margin="5,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="23"
                    Foreground="#fff"
                    Text="{DynamicResource restrooms_str}" />
            </StackPanel>

            <Rectangle
                Grid.Column="6"
                Width="3"
                Height="50"
                Fill="#fff"
                Opacity=".7" />

            <StackPanel
                Grid.Column="7"
                HorizontalAlignment="Center"
                Cursor="Hand"
                Orientation="Horizontal">
                <Image
                    Width="45"
                    Height="50"
                    Margin="10,0"
                    Source="/Assets/Images/EmergencyExit.png" />
                <TextBlock
                    Margin="5,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="23"
                    Foreground="#fff"
                    Text="{DynamicResource exit_str}" />
            </StackPanel>


        </Grid>
    </Border>
</UserControl>
