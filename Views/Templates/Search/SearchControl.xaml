<UserControl
    x:Class="MallMapKiosk.Views.Templates.Search.SearchControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="70"
    d:DesignWidth="750"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border
        Grid.ColumnSpan="2"
        Background="Transparent"
        BorderBrush="#69DFFA"
        BorderThickness="1"
        CornerRadius="40">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.ColumnSpan="3"
                Padding="10"
                Background="#fff"
                CornerRadius="40"
                Opacity=".1" />

            <Image
                Width="30"
                Height="30"
                Margin="20,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Source="/Assets/Images/Search.png" />


            <Grid Grid.Column="1">

                <TextBlock
                    Margin="7,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Kodchasan Regular"
                    FontSize="20"
                    Foreground="#fff"
                    IsHitTestVisible="False"
                    Opacity=".8"
                    Text="{DynamicResource search_str}"
                    Visibility="{Binding EmptyParam, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <TextBox
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="20"
                    Foreground="#fff"
                    Text="{Binding SearchParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

        </Grid>
    </Border>
</UserControl>