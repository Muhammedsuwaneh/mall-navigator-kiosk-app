<UserControl
    x:Class="MallMapKiosk.Views.Templates.Map.MapControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:MallMapKiosk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Map"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:MultiplyConverter x:Key="MultiplyConverter" />
        <c:PinBrushConverter x:Key="PinBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <!--  Zoomable Container  -->
        <Border ClipToBounds="True">
            <Grid x:Name="MapContainer" RenderTransformOrigin="0.5,0.5">

                <Grid.RenderTransform>
                    <ScaleTransform x:Name="MapScaleTransform" ScaleX="{Binding ScaleX}" ScaleY="{Binding ScaleY}" />
                </Grid.RenderTransform>

                <!--  Map  -->
                <Grid.Background>
                    <ImageBrush ImageSource="/Assets/Images/Map.png" Stretch="Uniform" />
                </Grid.Background>

                <Image
                    x:Name="kiosk_image"
                    Width="50"
                    Height="50"
                    Margin="700,125,770,473"
                    VerticalAlignment="Top"
                    Stretch="UniformToFill"
                    Source="/Assets/Images/kiosk.png" />

                <!--  Pins Layer  -->
                <ItemsControl ItemsSource="{Binding VisiblePins}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style>
                            <Setter Property="Canvas.Left">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource MultiplyConverter}">
                                        <Binding Path="X" />
                                        <Binding ElementName="MapContainer" Path="ActualWidth" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>

                            <Setter Property="Canvas.Top">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource MultiplyConverter}">
                                        <Binding Path="Y" />
                                        <Binding ElementName="MapContainer" Path="ActualHeight" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Grid Margin="15" Cursor="Hand">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="1"
                                    MaxWidth="150"
                                    MaxHeight="50"
                                    Margin="0,0,0,10"
                                    Padding="12"
                                    Panel.ZIndex="3"
                                    Background="{Binding Category, Converter={StaticResource PinBrushConverter}}"
                                    CornerRadius="12">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontFamily="pack://application:,,,/Assets/Fonts/#Kodchasan Bold"
                                        Foreground="#fff"
                                        Text="{Binding Name}"
                                        TextWrapping="Wrap" />
                                </Border>

                                <Polygon
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Fill="{Binding Category, Converter={StaticResource PinBrushConverter}}"
                                    Points="0,0 20,0 10,10" />

                            </Grid>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </Border>


    </Grid>
</UserControl>


