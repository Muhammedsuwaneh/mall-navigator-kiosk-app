<UserControl
    x:Class="MallMapKiosk.Views.Templates.Map.MapControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Map"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="1500"
    mc:Ignorable="d">
    <Grid>
        <!--  Zoomable Container  -->
        <Border ClipToBounds="True">
            <Grid x:Name="MapContainer" RenderTransformOrigin="0.5,0.5">

                <Grid.RenderTransform>
                    <ScaleTransform x:Name="MapScaleTransform" ScaleX="1" ScaleY="1" />
                </Grid.RenderTransform>

                <!--  Map  -->
                <Grid.Background>
                    <ImageBrush ImageSource="/Assets/Images/Map.png" Stretch="Uniform" />
                </Grid.Background>

            </Grid>
        </Border>

    </Grid>
</UserControl>