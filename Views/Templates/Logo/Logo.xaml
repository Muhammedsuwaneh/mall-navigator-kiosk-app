<UserControl
    x:Class="MallMapKiosk.Views.Templates.Logo.Logo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Logo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="90"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Image Source="/Assets/Images/logo.png" />

        <Border
            Grid.Column="1"
            Padding="1"
            VerticalAlignment="Center"
            BorderBrush="#69DFFA"
            BorderThickness="0,0,0,1">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="25"
                    Foreground="#69DFFA"
                    Text="AVANT-GARDE" />
                <TextBlock
                    Margin="10,0"
                    FontFamily="pack://application:,,,/Assets/Fonts/#Khula Regular"
                    FontSize="25"
                    Foreground="#fff"
                    Text="{DynamicResource welcome_str_top}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
