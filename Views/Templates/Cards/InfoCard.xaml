<UserControl
    x:Class="MallMapKiosk.Views.Templates.Cards.InfoCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:MallMapKiosk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Templates.Cards"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="170"
    d:DesignWidth="350"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:PinBrushConverter x:Key="PinBrushConverter" />
    </UserControl.Resources>

    <Border
        Width="350"
        Padding="15"
        Background="White"
        BorderBrush="{Binding SelectedPin.Category, Converter={StaticResource PinBrushConverter}}"
        BorderThickness="2"
        CornerRadius="20">

        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.2" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse
                        Width="10"
                        Height="10"
                        VerticalAlignment="Center"
                        Fill="{Binding SelectedPin.Category, Converter={StaticResource PinBrushConverter}}" />

                    <TextBlock
                        Margin="8,0,0,0"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#222"
                        Text="{Binding SelectedPin.Name}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding CloseCardCommand}"
                    Cursor="Hand">
                    <TextBlock
                        FontSize="18"
                        Foreground="#999"
                        Text="✕" />
                </Button>
            </Grid>

            <TextBlock
                Grid.Row="1"
                Margin="0,5,0,0"
                FontSize="14"
                Foreground="{Binding SelectedPin.Category, Converter={StaticResource PinBrushConverter}}"
                Text="{Binding SelectedPin.Label}" />

            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,0"
                Orientation="Vertical">

                <StackPanel Margin="0,2" Orientation="Horizontal">
                    <TextBlock FontSize="12" Text="📍" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="#555"
                        Text="{Binding SelectedPin.Floor}" />
                </StackPanel>

                <StackPanel Margin="0,2" Orientation="Horizontal">
                    <TextBlock FontSize="12" Text="⏰" />
                    <TextBlock
                        Margin="5,0,0,0"
                        FontSize="12"
                        Foreground="#555"
                        Text="{Binding SelectedPin.WorkHours}" />
                </StackPanel>
            </StackPanel>

            <TextBlock
                Grid.Row="3"
                Margin="0,10,0,0"
                FontSize="13"
                Foreground="#444"
                Text="{Binding SelectedPin.Description}"
                TextWrapping="Wrap" />

        </Grid>
    </Border>
</UserControl>
