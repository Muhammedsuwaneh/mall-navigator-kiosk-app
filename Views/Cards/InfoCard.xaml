<UserControl
    x:Class="MallMapKiosk.Views.Cards.InfoCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:MallMapKiosk.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Cards"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="200"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <c:PinBrushConverter x:Key="PinBrushConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Grid.RowSpan="2"
            Grid.ColumnSpan="2"
            Background="#fff"
            BorderBrush="red"
            BorderThickness="2"
            CornerRadius="20"
            Opacity=".7" />

        <!--  - title and icon  -->
        <StackPanel
            Margin="15,10,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Image Source="/Assets/Images/Shop.png" />
            <TextBlock
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="#333"
                Text="STORES" />
        </StackPanel>

        <Button />

    </Grid>
</UserControl>
