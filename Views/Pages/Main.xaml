<Page
    x:Class="MallMapKiosk.Views.Pages.Main"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MallMapKiosk.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mp="clr-namespace:MallMapKiosk.Views.Templates.Map"
    xmlns:mu="clr-namespace:MallMapKiosk.Views.Templates.Menu"
    Title="Main"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70" />
            <ColumnDefinition />
            <ColumnDefinition Width="70" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="100" />
            <RowDefinition />
            <RowDefinition Height="150" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <!--  overlay  -->
        <Canvas
            Grid.RowSpan="5"
            Grid.ColumnSpan="3"
            Panel.ZIndex="1"
            Background="#000"
            Opacity=".5" />

        <!--  - media  -->
        <MediaElement
            Grid.RowSpan="5"
            Grid.ColumnSpan="3"
            LoadedBehavior="Play"
            Source="{Binding VideoPath}"
            UnloadedBehavior="Stop">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MediaEnded">
                    <i:InvokeCommandAction Command="{Binding MediaEndedCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </MediaElement>

        <!--  - top section  -->

        <!--  map  -->

        <mp:MapControl
            Grid.Row="2"
            Grid.Column="1"
            Panel.ZIndex="3"
            DataContext="{Binding}" />


        <!--  control buttons  -->

        <!--  Menu section  -->
        <Grid
            Grid.Row="3"
            Grid.Column="1"
            Panel.ZIndex="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="70" />
                <ColumnDefinition Width="550" />
            </Grid.ColumnDefinitions>

            <mu:MenuControl
                Height="80"
                VerticalAlignment="Center"
                DataContext="{Binding}" />

        </Grid>

    </Grid>
</Page>
